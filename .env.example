# Au2fut — CME micro futures prop edge harness
# Copy to .env and adjust. This phase is RESEARCH ONLY: no live keys are used.

# ── Prop challenge selection (drives core/prop_rules.load_rules_from_env) ─────
FUT_PROP_PRESET=topstep_50k        # topstep_50k | topstep_150k | apex_50k | apex_100k
# Optional $-value overrides (leave unset to use the preset):
# FUT_PROP_ACCOUNT_SIZE=50000
# FUT_PROP_MAX_TRAILING_LOSS=2000
# FUT_PROP_TRAILING_MODE=eod        # eod | intraday
# FUT_PROP_DAILY_LOSS_LIMIT=1000
# FUT_PROP_PROFIT_TARGET=3000
# FUT_PROP_MIN_DAYS=2
# FUT_PROP_CONSISTENCY_PCT=0

# ── Cost model overrides (per-contract; defaults in core/instruments.py) ─────
# Set these to YOUR prop plan's actual fee schedule before trusting prop_mc EV.
# FUT_RT_COMMISSION=1.00            # $ round-turn commission per micro contract
# FUT_SLIPPAGE_TICKS=1.0           # ticks lost to slippage per round turn
# The MR edge dies at 3-tick slippage — stress-test with FUT_SLIPPAGE_TICKS=2/3.

# ── Data source (pluggable; default yahoo) ───────────────────────────────────
# yahoo (free, intraday capped ~60d) | databento | ibkr | csv
FUT_DATA_SOURCE=yahoo

# databento (CME Globex, multi-year minute/tick — recommended for OOS validation):
# DATABENTO_API_KEY=db-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ibkr (needs TWS or IB Gateway running locally):
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497                    # 7497 paper TWS / 4002 gateway
# IBKR_CLIENT_ID=17
# IBKR_USE_RTH=false

# csv (export your own bars; default path data/csv/<SYMBOL>_<interval>.csv):
# columns: timestamp(open ISO or unix),open,high,low,close[,volume]
# FUT_CSV_PATH=C:\path\to\MES_5m.csv

# ── LIVE TRADING IS DISABLED IN THIS PHASE ───────────────────────────────────
# No execution code exists yet. Prove the edge OOS + forward live-paper first.
LIVE_ENABLED=false
